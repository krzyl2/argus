# Argus — local dev / edge environment.
# Copy to deploy/.env and fill in. NEVER commit the real .env (CONF-03).
#   cp deploy/.env.example deploy/.env

# ── Home Assistant WebSocket (required — orchestrator reads live sensor events) ──
# Use a long-lived access token: HA → Profile → Security → Long-lived access tokens.
ARGUS_HA_URL=ws://homeassistant.local:8123/api/websocket
ARGUS_HA_TOKEN=paste-long-lived-token-here

# ── MQTT broker ──
# docker-compose.dev.yml runs a local anonymous mosquitto — leave these as-is for dev.
# For edge/prod (docker-compose.edge.yml) point at your real broker + credentials.
ARGUS_MQTT_HOST=mosquitto
ARGUS_MQTT_PORT=1883
ARGUS_MQTT_USER=
ARGUS_MQTT_PASSWORD=

# ── Detector gRPC endpoint ──
# dev: insecure in-network detector (docker-compose.dev.yml). edge: https://gpu-host:50051 + mTLS.
ARGUS_DETECTOR_ENDPOINT=http://detector:50051

# ── mTLS cert paths (edge/prod only — leave empty for insecure local dev) ──
# When all three are empty the orchestrator uses an insecure channel and the detector
# binds an insecure port. Populate only for the two-host edge deployment.
ARGUS_TLS_CA=
ARGUS_TLS_CERT=
ARGUS_TLS_KEY=

# ── Entity config file (inside the container) ──
ARGUS_ENTITIES_PATH=/app/entities.yaml

# ── InfluxDB batch path (optional — leave URL empty to run streaming-only) ──
ARGUS_INFLUX_URL=
ARGUS_INFLUX_TOKEN=
ARGUS_INFLUX_ORG=
ARGUS_INFLUX_BUCKET=
ARGUS_INFLUX_MEASUREMENT=homeassistant
ARGUS_INFLUX_VALUE_FIELD=value

# ── Batch scheduling (optional — defaults shown) ──
ARGUS_BATCH_INTERVAL_MIN=10
ARGUS_NIGHTLY_FIT_HOUR=2
